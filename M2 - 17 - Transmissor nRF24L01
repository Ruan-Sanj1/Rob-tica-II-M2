char mensagem[] = "pressionado";

#include <RF24.h>

#define pinoBotao 
#define pinoCE 
#define pinoCSN 

#define endereco 5995
RF24 radio(pinoCE, pinoCSN);

void setup() {
pinMode(pinoBotao, INPUT_PULLUP);
radio.begin();
radio.openWritingPipe(endereco);
radio.stopListening();
}

void loop() {
if (digitalRead(pinoBotao) == LOW) {
   radio.write(&mensagem, );
   delay(400);
}
}
